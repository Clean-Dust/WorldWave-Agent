# Worldwave environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real keys.

# Required: DeepSeek API key (get one at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional: OpenAI API key (for multimodal, GPT-4o, etc.)
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Anthropic API key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional: OpenRouter API key (for multi-provider access)
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Optional: vLLM / local LLM (Ollama, LM Studio, etc.)
# CUSTOM_API_KEY=your-custom-key
# CUSTOM_BASE_URL=http://localhost:11434/v1

# Optional: Telegram bot token (for Telegram gateway)
# TELEGRAM_WW_TOKEN=1234567890:ABCdef...

# Optional: WW server port (default: 9300)
# WW_PORT=9300
# Bind address (prefer 127.0.0.1 when only local/Telegram access is needed)
# WW_HOST=127.0.0.1

# ── Security / runtime flags ──
# Prefer a long random key: python -c "import secrets;print(secrets.token_urlsafe(32))"
# WW_API_KEY=
# WW_APPROVAL_MODE=auto   # auto | hitl | deny
# WW_PAIRING_AUTO_APPROVE=false  # NEVER true in production (auto-whitelists any DM)
# WW_SKIP_AUTO_EVOLUTION=   # set true only for debug/test / memory-constrained hosts
# WW_FORCE_COMPUTER_USE=    # force register CU tools even on headless hosts
# Shared secret for public P2P bootstrap tracker register/unregister
# WW_TRACKER_TOKEN=

