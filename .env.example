# Worldwave environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real keys.
# Providers: DeepSeek, OpenAI, Anthropic, OpenRouter, Gemini, xAI, Groq,
#   Fireworks, Together, Mistral, Moonshot, DeepInfra, Ollama, custom OpenAI-compatible.
# Optional base URL overrides use *_BASE_URL (see comments).

# ── LLM API keys (any one is enough to chat) ──

# DeepSeek (default) — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI — https://platform.openai.com
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter (multi-model gateway) — https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Gemini (AI Studio OpenAI-compat); GOOGLE_API_KEY also accepted
# GEMINI_API_KEY=your-gemini-key-here
# GOOGLE_API_KEY=your-google-ai-studio-key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# xAI (Grok) — https://console.x.ai
# XAI_API_KEY=xai-your-key-here
# XAI_BASE_URL=https://api.x.ai/v1

# Groq — https://console.groq.com
# GROQ_API_KEY=gsk_your-key-here
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Fireworks — https://fireworks.ai
# FIREWORKS_API_KEY=fw_your-key-here
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Together AI — https://together.ai
# TOGETHER_API_KEY=your-together-key
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Mistral — https://console.mistral.ai
# MISTRAL_API_KEY=your-mistral-key
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Moonshot (Kimi) — https://platform.moonshot.cn
# MOONSHOT_API_KEY=your-moonshot-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# DeepInfra — https://deepinfra.com
# DEEPINFRA_API_KEY=your-deepinfra-key
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# Ollama (local) — key optional; enable with WW_USE_OLLAMA=1 or OLLAMA_BASE_URL
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# WW_USE_OLLAMA=1
# OLLAMA_HOST=127.0.0.1:11434

# Custom OpenAI-compatible (vLLM, LM Studio, etc.)
# CUSTOM_API_KEY=your-custom-key
# CUSTOM_BASE_URL=http://localhost:11434/v1

# Default model override (optional; installer sets this when non-DeepSeek)
# WW_MODEL=deepseek/deepseek-v4-flash
# WW_PROVIDER=deepseek

# Optional: Telegram bot (DM works with token only; group needs workspace)
# TELEGRAM_WW_TOKEN=1234567890:ABCdef...
# TELEGRAM_WW_WORKSPACE=   # optional; group chat id. DMs work with token only.
# WW_PAIRING_AUTO_APPROVE=false  # true only for personal single-user nodes
# Same Timeline (single-user): terminal/http + owner Telegram share one entity
# WW_SINGLE_USER=1             # default true; set 0 for strict multi-user
# WW_OWNER_TELEGRAM_ID=        # owner Telegram user id (or positive DM workspace id)

# Optional: WW server port (default: 9300)
# WW_PORT=9300
# Bind address (prefer 127.0.0.1 when only local/Telegram access is needed)
# WW_HOST=127.0.0.1

# ── Security / runtime flags ──
# Prefer a long random key: python -c "import secrets;print(secrets.token_urlsafe(32))"
# WW_API_KEY=
# WW_APPROVAL_MODE=auto   # auto | hitl | deny
# WW_SKIP_AUTO_EVOLUTION=   # set true only for debug/test / memory-constrained hosts
# WW_FORCE_COMPUTER_USE=    # force register CU tools even on headless hosts
# Shared secret for public P2P bootstrap tracker register/unregister
# WW_TRACKER_TOKEN=
