# Worldwave environment configuration template
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ── LLM Provider Configuration ──
# At least one provider's API key is required

# DeepSeek API (default)
DEEPSEEK_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# OpenRouter API (access to multiple models)
OPENROUTER_API_KEY=

# ── Computer Use Vision (optional) ──
# Vision API for Computer Use (default: OpenRouter Qwen2.5-VL)
WW_VISION_API_KEY=
WW_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct

# ── MQTT Communication (optional) ──
# MQTT broker for inter-node agent communication
WW_MQTT_HOST=localhost
WW_MQTT_PORT=1883

# ── SSH Remote Hosts (optional) ──
# JSON format: {"node1":{"host":"x.x","user":"u","password":"p"}}
WW_SSH_HOSTS=
# Format: {"node1":{"host":"x.x","user":"u","password":"p"}}

# ── Gateway Configuration (optional) ──

# Telegram Gateway
# Bot token from @BotFather
# Workspace = Telegram chat/group ID (negative = group)
TELEGRAM_WW_TOKEN=
TELEGRAM_WW_WORKSPACE=

# Discord Gateway
# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=

# Webhook Gateway (optional)
# Receive external HTTP webhook pushes
WW_WEBHOOK_SECRET=

# ── Additional Services (optional) ──
# Image generation backend URL (empty = disabled)
WW_IMAGE_GEN_URL=
# Scheduler API URL (default: same as server port)
WW_SCHEDULER_URL=http://localhost:9300

# ── Service Configuration (optional) ──
WW_PORT=9300
WW_HOME=${HOME}/worldwave
WW_CONFIG=${HOME}/.ww
# Memory system daily consolidation schedule (-1=disabled, 0-23=hour, default 3 AM)
WW_MEMORY_SLEEP_HOUR=3
# Dynamic idle detection (minutes, 0=disabled, >0 consolidates after X minutes idle)
WW_MEMORY_IDLE_THRESHOLD=0
# Hippocampus buffer capacity (default 100, forced consolidation when full)
WW_HIPPOCAMPUS_CAP=100
# Orphan GC age (days — orphan nodes with zero links older than this are auto-archived)
WW_MEMORY_GC_AGE_DAYS=30
# Semantic synthesis trust threshold (when both facts' trust > this, trigger LLM mediation)
WW_MEMORY_SYNTHESIS_TRUST=0.7
