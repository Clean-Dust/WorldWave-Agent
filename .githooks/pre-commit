#!/bin/bash
# Pre-commit hook: scan for hardcoded secrets before committing
# Install: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
NC='\033[0m'

echo "🔍 Scanning for secrets..."

# Patterns that should NEVER be committed
PATTERNS=(
    'sk-[a-zA-Z0-9]{20,}'                   # OpenAI/DeepSeek API key
    'sk-or-[a-zA-Z0-9]{20,}'                # OpenRouter API key
    'sk-ant-[a-zA-Z0-9]{20,}'               # Anthropic API key
    '[0-9]{8,10}:[a-zA-Z0-9_-]{35,}'        # Telegram bot token
    'ghp_[a-zA-Z0-9]{36}'                   # GitHub PAT
    'gho_[a-zA-Z0-9]{36}'                   # GitHub OAuth token
    'ghu_[a-zA-Z0-9]{36}'                   # GitHub user token
    'ghs_[a-zA-Z0-9]{36}'                   # GitHub server token
    'xox[bpras]-[a-zA-Z0-9-]+'             # Slack token
    'AIza[0-9A-Za-z_-]{35}'                 # Google API key
    'ya29\.[0-9A-Za-z_-]+'                  # Google OAuth token
    '-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----'  # Private key
    'AKIA[0-9A-Z]{16}'                      # AWS Access Key
)

# Files to skip (tests, examples, docs)
SKIP_PATHS='tests/|\.env\.example|\.secrets\.baseline|\.git/|\.venv/|__pycache__|\.pre-commit-config\.yaml'

FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for file in $STAGED_FILES; do
    # Skip allowed paths
    if echo "$file" | grep -qE "$SKIP_PATHS"; then
        continue
    fi
    
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q 'binary'; then
        continue
    fi
    
    for pattern in "${PATTERNS[@]}"; do
        if matches=$(git show ":$file" 2>/dev/null | grep -nE "$pattern" 2>/dev/null); then
            if [ -n "$matches" ]; then
                # Filter false positives: references in env var docs, comments explaining env vars
                FILTERED=$(echo "$matches" | grep -vE '(DEEPSEEK_API_KEY|OPENAI_API_KEY|OPENROUTER_API_KEY|ANTHROPIC_API_KEY|TELEGRAM.*TOKEN|API_KEY|_KEY|=)' || true)
                if [ -n "$FILTERED" ]; then
                    echo -e "${RED}⛔ SECRET DETECTED in $file:${NC}"
                    echo "$FILTERED"
                    echo ""
                    FOUND=1
                fi
            fi
        fi
    done
done

if [ $FOUND -eq 1 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  COMMIT BLOCKED: Hardcoded secrets detected${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  These patterns look like API keys or tokens."
    echo "  Use environment variables (.env) instead."
    echo "  See .env.example for reference."
    echo ""
    echo "  To bypass (only for tests/mocks):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

echo "✓ No secrets found"
exit 0
